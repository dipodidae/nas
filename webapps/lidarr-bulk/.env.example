# Required
LIDARR_URL=http://lidarr:8686
LIDARR_API_KEY=replace-me

# Optional — session login (both required to enable)
APP_USERNAME=
APP_PASSWORD=

# Optional — bearer-token gate on /api/* (for programmatic clients)
APP_BEARER_TOKEN=

# Optional — session signing key. Auto-generated to /config/session.key if unset.
# NUXT_SESSION_PASSWORD=

CONFIG_DIR=/config
RATE_LIMIT_PER_MINUTE=30
BODY_LIMIT_BYTES=262144
NITRO_HOST=0.0.0.0
NITRO_PORT=3000
