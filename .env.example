ADMIN_EMAIL=admin@4eva.me
API_KEY_JELLYFIN=your-jellyfin-api-key
API_KEY_LAZYLIBRARIAN=your-lazylibrarian-api-key
API_KEY_LIDARR=your-lidarr-api-key
API_KEY_PROWLARR=your-prowlarr-api-key
API_KEY_RADARR=your-radarr-api-key
API_KEY_SLSKD=your-slskd-api-key
API_KEY_SONARR=your-sonarr-api-key
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token-here
CONFIG_DIRECTORY=/mnt/drive/.docker-config
JELLYFIN_CACHE_DIRECTORY=/tmp/jellyfin-cache
JELLYFIN_PUBLISHED_URL=https://jellyfin.${PUBLIC_DOMAIN}
OVERSEERR_PUBLISHED_URL=https://overseerr.${PUBLIC_DOMAIN}
PGID=1000
PLEX_IDENTIFIER=your-plex-identifier
PLEX_SERVER_NAME=YourServerName
PLEX_TOKEN=your-plex-token
PUBLIC_DOMAIN=4eva.me
PUID=1000
QBITTORRENT_PASS=change-this-password
QBITTORRENT_USER=admin
SHARE_DIRECTORY=/mnt/drive
TZ=Europe/Amsterdam
WATCHTOWER_SCHEDULE=0 0 4 * * *

# slskd — Soulseek network credentials
SLSKD_SLSK_USERNAME=your-soulseek-username
SLSKD_SLSK_PASSWORD=your-soulseek-password

# slskd — WebUI login credentials
SLSKD_USERNAME=admin
SLSKD_PASSWORD=change-this-password

# DeepL — subtitle translation via Lingarr (https://www.deepl.com/account/summary)
DEEPL_API_KEY=your-deepl-api-key-here

# playlist-generator (webapps/jellyfin-playlist-generator submodule)
PLAYLIST_GENERATOR_USERNAME=admin
PLAYLIST_GENERATOR_PASSWORD=change-this-password
PLAYLIST_GENERATOR_DB_PASSWORD=change-this-db-password
PLAYLIST_GENERATOR_SCAN_THREADS=8
# Third-party API keys (Last.fm key required for enrichment; OpenAI/Discogs optional)
LASTFM_API_KEY=your-lastfm-api-key
LASTFM_API_SECRET=
OPENAI_API_KEY=your-openai-api-key
# Discogs: either a personal access token OR a consumer key/secret pair.
DISCOGS_TOKEN=
DISCOGS_CONSUMER_KEY=
DISCOGS_CONSUMER_SECRET=
# MusicBrainz contact email (required by MB API ToS; unblocks ID resolution ->
# album legitimacy + RYM matching). RateYourMusic scraping is opt-in and slow.
MUSICBRAINZ_CONTACT=your-email@example.com
RYM_SCRAPE_ENABLED=false
RYM_SCRAPE_DELAY_MIN=2.0
RYM_SCRAPE_DELAY_MAX=5.0
# "Push to Jellyfin" export uses API_KEY_JELLYFIN (above) + the target Jellyfin user id.
# Find it via: curl -H "X-Emby-Token: $API_KEY_JELLYFIN" http://jellyfin:8096/Users
JELLYFIN_USER_ID=your-jellyfin-user-id
